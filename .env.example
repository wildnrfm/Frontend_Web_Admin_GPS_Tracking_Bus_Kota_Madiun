APP_NAME="Mobitra Admin"
# Gunakan 'local' saat development, 'production' saat deploy ke server
APP_ENV=local
APP_KEY=
# Jalankan: php artisan key:generate
APP_DEBUG=true
# URL web admin ini sendiri
# Development: http://localhost:8001
# Production: https://admin.yourdomain.com
APP_URL=http://localhost:8001

# ── API Configuration ─────────────────────────────────────────────────
# Set ke URL backend API (folder /api).
# Development lokal        : http://localhost:8000/api
# Development via ngrok    : https://xxxx.ngrok-free.app/api
# Production               : https://api.yourdomain.com/api
API_BASE_URL=http://localhost:8000/api

# Encryption & Authentication
BCRYPT_ROUNDS=12

# Logging
LOG_CHANNEL=stack

# Session Configuration
SESSION_DRIVER=file
SESSION_LIFETIME=2880
